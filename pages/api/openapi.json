{
  "openapi": "3.1.0",
  "info": {
    "title": "Assistant API",
    "version": "2.0.0",
    "description": "API quản lý lịch Google/Lark, giao task, đọc Drive, đọc group chat"
  },
  "servers": [
    {
      "url": "https://assistant-xi-blond.vercel.app"
    }
  ],
  "paths": {
    "/api/events": {
      "get": {
        "operationId": "getCalendarEvents",
        "summary": "Lấy danh sách lịch",
        "parameters": [
          { "name": "uid", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "start", "in": "query", "schema": { "type": "integer" } },
          { "name": "end", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/events/create": {
      "post": {
        "operationId": "createCalendarEvent",
        "summary": "Tạo lịch mới",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["uid", "title", "start", "end"],
                "properties": {
                  "uid": { "type": "string" },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "start": { "type": "integer" },
                  "end": { "type": "integer" },
                  "attendees": { "type": "array", "items": { "type": "string" } },
                  "location": { "type": "string" },
                  "target": { "type": "string", "enum": ["google", "lark", "both"], "default": "both" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/events/update": {
      "post": {
        "operationId": "updateCalendarEvent",
        "summary": "Sửa lịch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["uid", "event_id", "source"],
                "properties": {
                  "uid": { "type": "string" },
                  "event_id": { "type": "string" },
                  "source": { "type": "string", "enum": ["google", "lark"] },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "start": { "type": "integer" },
                  "end": { "type": "integer" },
                  "location": { "type": "string" },
                  "sync_to_other": { "type": "boolean", "default": true }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/events/delete": {
      "post": {
        "operationId": "deleteCalendarEvent",
        "summary": "Xóa lịch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["uid", "event_id", "source"],
                "properties": {
                  "uid": { "type": "string" },
                  "event_id": { "type": "string" },
                  "source": { "type": "string", "enum": ["google", "lark"] },
                  "delete_synced": { "type": "boolean", "default": true }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/events/attendees": {
      "post": {
        "operationId": "manageEventAttendees",
        "summary": "Thêm hoặc xóa người họp",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["uid", "event_id", "source", "action", "attendees"],
                "properties": {
                  "uid": { "type": "string" },
                  "event_id": { "type": "string" },
                  "source": { "type": "string", "enum": ["google", "lark"] },
                  "action": { "type": "string", "enum": ["add", "remove"] },
                  "attendees": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/tasks/create": {
      "post": {
        "operationId": "createTask",
        "summary": "Giao task mới",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["uid", "title"],
                "properties": {
                  "uid": { "type": "string" },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "assignee_email": { "type": "string" },
                  "assignee_name": { "type": "string" },
                  "due_date": { "type": "string" },
                  "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
                  "create_calendar_event": { "type": "boolean", "default": true }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/tasks/list": {
      "get": {
        "operationId": "listTasks",
        "summary": "Lấy danh sách tasks",
        "parameters": [
          { "name": "uid", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["pending", "overdue"] } },
          { "name": "start", "in": "query", "schema": { "type": "integer" } },
          { "name": "end", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/drive/list": {
      "get": {
        "operationId": "listDriveFolder",
        "summary": "Đọc folder Drive",
        "parameters": [
          { "name": "uid", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "folder_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "recursive", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/drive/report": {
      "get": {
        "operationId": "getDriveReport",
        "summary": "Báo cáo tiến độ Drive",
        "parameters": [
          { "name": "uid", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "folder_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "period", "in": "query", "schema": { "type": "string", "enum": ["day", "week", "month", "quarter", "year"] } },
          { "name": "date", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/lark/groups": {
      "get": {
        "operationId": "listLarkGroups",
        "summary": "Tìm group chat Lark",
        "parameters": [
          { "name": "uid", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "keyword", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/api/lark/messages": {
      "get": {
        "operationId": "readLarkMessages",
        "summary": "Đọc tin nhắn group Lark",
        "parameters": [
          { "name": "uid", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "chat_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "since", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Thành công" } }
      }
    }
  }
}