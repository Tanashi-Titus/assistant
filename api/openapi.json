{
  "openapi": "3.1.0",
  "info": {
    "title": "Assistant Calendar & Drive API",
    "version": "2.0.0",
    "description": "API cho GPT Custom: quản lý lịch Google/Lark, giao task, đọc Drive, đọc group chat Lark"
  },
  "servers": [
    {
      "url": "https://assistant-git-main-akito-s-projects2.vercel.app"
    }
  ],
  "paths": {
    "/api/events": {
      "get": {
        "operationId": "getCalendarEvents",
        "summary": "Lấy danh sách lịch từ Lark và Google Calendar",
        "parameters": [
          { "name": "api_key", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "start", "in": "query", "schema": { "type": "integer", "description": "Unix timestamp bắt đầu" } },
          { "name": "end", "in": "query", "schema": { "type": "integer", "description": "Unix timestamp kết thúc" } }
        ],
        "responses": {
          "200": {
            "description": "Danh sách events kèm event_id, attendees",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        }
      }
    },
    "/api/events/create": {
      "post": {
        "operationId": "createCalendarEvent",
        "summary": "Tạo lịch mới trên Google/Lark/cả hai, kèm attendees",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["api_key", "title", "start", "end"],
                "properties": {
                  "api_key": { "type": "string" },
                  "title": { "type": "string", "description": "Tên sự kiện" },
                  "description": { "type": "string" },
                  "start": { "type": "integer", "description": "Unix timestamp bắt đầu" },
                  "end": { "type": "integer", "description": "Unix timestamp kết thúc" },
                  "attendees": { "type": "array", "items": { "type": "string" }, "description": "Danh sách email người tham dự" },
                  "location": { "type": "string" },
                  "target": { "type": "string", "enum": ["google", "lark", "both"], "default": "both" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Event đã tạo kèm event_id", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/events/update": {
      "post": {
        "operationId": "updateCalendarEvent",
        "summary": "Sửa lịch đã có, tự động sync sang bên kia",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["api_key", "event_id", "source"],
                "properties": {
                  "api_key": { "type": "string" },
                  "event_id": { "type": "string", "description": "ID event cần sửa" },
                  "source": { "type": "string", "enum": ["google", "lark"] },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "start": { "type": "integer" },
                  "end": { "type": "integer" },
                  "location": { "type": "string" },
                  "sync_to_other": { "type": "boolean", "default": true, "description": "Tự động sync sang bên kia" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Kết quả update", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/events/delete": {
      "post": {
        "operationId": "deleteCalendarEvent",
        "summary": "Xóa lịch, có thể xóa cả bên sync",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["api_key", "event_id", "source"],
                "properties": {
                  "api_key": { "type": "string" },
                  "event_id": { "type": "string" },
                  "source": { "type": "string", "enum": ["google", "lark"] },
                  "delete_synced": { "type": "boolean", "default": true, "description": "Xóa cả event đã sync bên kia" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Kết quả xóa", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/events/attendees": {
      "post": {
        "operationId": "manageEventAttendees",
        "summary": "Thêm hoặc xóa người tham gia cuộc họp",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["api_key", "event_id", "source", "action", "attendees"],
                "properties": {
                  "api_key": { "type": "string" },
                  "event_id": { "type": "string" },
                  "source": { "type": "string", "enum": ["google", "lark"] },
                  "action": { "type": "string", "enum": ["add", "remove"] },
                  "attendees": { "type": "array", "items": { "type": "string" }, "description": "Danh sách email" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Kết quả thêm/xóa attendees", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/tasks/create": {
      "post": {
        "operationId": "createTask",
        "summary": "Giao task mới — tạo calendar event với prefix [TASK]",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["api_key", "title"],
                "properties": {
                  "api_key": { "type": "string" },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "assignee_email": { "type": "string" },
                  "assignee_name": { "type": "string" },
                  "due_date": { "type": "string", "description": "ISO 8601 datetime" },
                  "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"], "default": "medium" },
                  "create_calendar_event": { "type": "boolean", "default": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Task đã tạo kèm event IDs", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/tasks/list": {
      "get": {
        "operationId": "listTasks",
        "summary": "Lấy danh sách tasks (filter events có prefix [TASK])",
        "parameters": [
          { "name": "api_key", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["pending", "overdue"] } },
          { "name": "start", "in": "query", "schema": { "type": "integer" } },
          { "name": "end", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Danh sách tasks", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/drive/list": {
      "get": {
        "operationId": "listDriveFolder",
        "summary": "Đọc folder bất kỳ trên Google Drive",
        "parameters": [
          { "name": "api_key", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "folder_id", "in": "query", "required": true, "schema": { "type": "string", "description": "Google Drive folder ID" } },
          { "name": "recursive", "in": "query", "schema": { "type": "string", "enum": ["true", "false"], "default": "false" } }
        ],
        "responses": {
          "200": { "description": "Danh sách files trong folder", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/drive/report": {
      "get": {
        "operationId": "getDriveReport",
        "summary": "Thống kê tiến độ folder theo ngày/tuần/tháng/quý/năm",
        "parameters": [
          { "name": "api_key", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "folder_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "period", "in": "query", "schema": { "type": "string", "enum": ["day", "week", "month", "quarter", "year"], "default": "week" } },
          { "name": "date", "in": "query", "schema": { "type": "string", "description": "Ngày tham chiếu (YYYY-MM-DD), mặc định hôm nay" } }
        ],
        "responses": {
          "200": { "description": "Báo cáo tiến độ với so sánh period trước", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/lark/groups": {
      "get": {
        "operationId": "listLarkGroups",
        "summary": "Tìm group chat Lark theo tên",
        "parameters": [
          { "name": "api_key", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "keyword", "in": "query", "schema": { "type": "string", "description": "Từ khóa tìm tên group" } }
        ],
        "responses": {
          "200": { "description": "Danh sách groups kèm chat_id", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/lark/messages": {
      "get": {
        "operationId": "readLarkMessages",
        "summary": "Đọc tin nhắn group Lark để summarize thông tin quan trọng",
        "parameters": [
          { "name": "api_key", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "chat_id", "in": "query", "required": true, "schema": { "type": "string", "description": "Chat ID lấy từ listLarkGroups" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50, "description": "Số tin nhắn tối đa (max 200)" } },
          { "name": "since", "in": "query", "schema": { "type": "string", "description": "Unix timestamp lấy tin từ thời điểm này" } }
        ],
        "responses": {
          "200": { "description": "Tin nhắn kèm summary_hint cho GPT", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    }
  }
}